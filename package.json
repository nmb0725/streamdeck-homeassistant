{
  "name": "streamdeck-homeassistant-vue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "validate": "streamdeck validate --no-update-check ./de.perdoctus.streamdeck.homeassistant.sdPlugin",
    "build-dev": "vite build --mode development --watch --sourcemap inline --minify false",
    "bundle": "streamdeck bundle -f --no-update-check ./de.perdoctus.streamdeck.homeassistant.sdPlugin",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@mdi/js": "^7.4.47",
    "axios": "1.13.5",
    "core-js": "^3.46.0",
    "home-assistant-js-websocket": "^9.6.0",
    "js-yaml": "4.1.1",
    "nunjucks": "3.2.4",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@elgato/cli": "^1.5.1",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.5.1",
    "npm-check-updates": "^19.1.2",
    "prettier": "^3.6.2",
    "sass": "^1.93.3",
    "vite": "^7.2.2"
  }
}
